{
  "title": "The 2 PM Incident",
  "service": "checkout-service",
  "severity": "SEV-1",
  "alert": "A production anomaly is active in checkout-service. Investigate before shipping a fix.",
  "timeLimitSeconds": 1200,
  "serviceDirectory": "checkout-service",
  "activeFile": "src/services/checkout-service.ts",
  "execution": {
    "language": "typescript",
    "runner": "webcontainer-node",
    "installCommand": ["npm", "install"],
    "testCommand": ["npm", "test"]
  }
}
